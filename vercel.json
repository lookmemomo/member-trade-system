{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/app.js"
    },
    {
      "source": "/admin/(.*)",
      "destination": "/frontend/admin/$1"
    },
    {
      "source": "/member/(.*)",
      "destination": "/frontend/member/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/admin/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}